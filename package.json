{
  "name": "@llanesleonardo/saas-product-shell",
  "version": "0.2.5",
  "private": false,
  "description": "SaaS product-shell kits (auth, Clerk helpers, tenancy, account, SQLite/Postgres, Stripe billing, email, API keys, AppShell UI) on saas-platform",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llanesleonardo/saas-product-shell.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./composition": "./src/composition/index.ts",
    "./db": "./src/db/index.ts",
    "./auth": "./src/auth/index.ts",
    "./tenancy": "./src/tenancy/index.ts",
    "./account": "./src/account/index.ts",
    "./billing": "./src/billing/index.ts",
    "./billing/catalog": "./src/billing/catalog.ts",
    "./email": "./src/email/index.ts",
    "./api-keys": "./src/api-keys/index.ts",
    "./api-keys/ui": "./src/api-keys/ui.tsx",
    "./ui": "./src/ui/index.ts",
    "./ui/theme-bootstrap": "./src/ui/theme/theme-bootstrap.ts",
    "./ui/tokens.css": "./src/ui/tokens.css",
    "./middleware": "./src/middleware.ts",
    "./errors": "./src/errors.ts"
  },
  "files": [
    "src",
    "docs",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:smoke": "tsx src/smoke.ts",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "prepublishOnly": "npm run check:boundaries && npm run typecheck",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@llanesleonardo/saas-platform": "0.3.0",
    "better-sqlite3": "^12.11.1",
    "pg": "^8.22.0"
  },
  "peerDependencies": {
    "@clerk/nextjs": ">=5.0.0",
    "next": ">=16.0.0",
    "react": ">=18.0.0",
    "stripe": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "@clerk/nextjs": { "optional": true },
    "stripe": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
